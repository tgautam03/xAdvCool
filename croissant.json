          "dataType": "sc:Float",
          "source": {
            "fileObject": {
              "@id": "metadata.parquet"
            },
            "extract": {
              "column": "u_inlet_val"
            }
          }
        },
        {
          "@type": "cr:Field",
          "@id": "samples/heat_power",
          "name": "heat_power",
          "description": "Total heat power input (lattice units)",
          "dataType": "sc:Float",
          "source": {
            "fileObject": {
              "@id": "metadata.parquet"
            },
            "extract": {
