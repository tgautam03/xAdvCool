{
  "@context": {
    "@language": "en",
    "@vocab": "https://schema.org/",
    "sc": "https://schema.org/",
    "cr": "http://mlcommons.org/croissant/",
    "dct": "https://purl.org/dc/terms/"
  },
  "@type": "sc:Dataset",
  "name": "xAdvCool",
  "description": "A benchmark dataset of 3D conjugate heat transfer (CHT) simulations for data-driven surrogate modeling of cold plate heat sinks. Contains Lattice Boltzmann simulations across 5 topology types (Straight Channels, Pin-Fin Staggered, Gyroid TPMS, Schwarz P TPMS, Schwarz D TPMS) and 10 heat source patterns, with water cooling through copper cold plates. Each sample maps a geometry mask and operating conditions to steady-state velocity, pressure, and temperature fields on a 148x128x32 lattice.",
  "dct:conformsTo": "http://mlcommons.org/croissant/1.0",
  "license": "https://creativecommons.org/licenses/by/4.0/",
  "url": "https://huggingface.co/datasets/tgautam03/xAdvCool",
  "version": "1.0.0",
  "citation": "Gautam, T. (2026). xAdvCool: A Benchmark Dataset for 3D Conjugate Heat Transfer Surrogate Modeling. NeurIPS Datasets and Benchmarks Track.",
  "creator": {
    "@type": "Person",
    "name": "Tushar Gautam"
  },
  "datePublished": "2026-03-31",
  "keywords": [
    "physics",
    "simulation",
    "cfd",
    "conjugate-heat-transfer",
    "lattice-boltzmann",
    "cold-plate",
    "topology-optimization",
    "surrogate-modeling"
  ],
  "distribution": [
    {
      "@type": "sc:FileObject",
      "@id": "data.h5",
      "name": "data.h5",
      "description": "HDF5 file containing all simulation samples. Each top-level group is a sample keyed by sample_id, containing 5 datasets (mask, heat_source, velocity, pressure, temperature) and scalar attributes.",
      "contentUrl": "https://huggingface.co/datasets/tgautam03/xAdvCool/resolve/main/data.h5",
      "encodingFormat": "application/x-hdf5",
      "sha256": "5cdb43ca08d57a206ef18e0f9940c57988d77483cbb24cc009ee69e38e6b1bf4"
    },
    {
      "@type": "sc:FileObject",
      "@id": "metadata.parquet",
      "name": "metadata.parquet",
      "description": "Parquet metadata index with scalar parameters and performance metrics for each sample.",
      "contentUrl": "https://huggingface.co/datasets/tgautam03/xAdvCool/resolve/main/metadata.parquet",
      "encodingFormat": "application/x-parquet",
      "sha256": "34159b84471848c5b823cf81cc5c90cf1ca2c78ef5cbc54cf06cf1c115f29768"
    }
  ],
  "recordSet": [
    {
      "@type": "cr:RecordSet",
      "@id": "samples",
      "name": "samples",
      "description": "Individual CHT simulation samples. 3D field data is stored in the HDF5 file; scalar metadata is in the Parquet file. Linked by sample_id.",
      "field": [
        {
          "@type": "cr:Field",
          "@id": "samples/sample_id",
          "name": "sample_id",
          "description": "Unique sample identifier (also the HDF5 group key)",
          "dataType": "sc:Text",
          "source": {
            "fileObject": {
              "@id": "metadata.parquet"
            },
            "extract": {
              "column": "sample_id"
            }
          }
        },
        {
          "@type": "cr:Field",
          "@id": "samples/design_name",
          "name": "design_name",
          "description": "Geometry topology type: Straight Channels, Pin-Fin Staggered, Gyroid TPMS, Schwarz P TPMS, or Schwarz D TPMS",
          "dataType": "sc:Text",
          "source": {
            "fileObject": {
              "@id": "metadata.parquet"
            },
            "extract": {
              "column": "design_name"
            }
          }
        },
        {
          "@type": "cr:Field",
          "@id": "samples/heat_source_type",
          "name": "heat_source_type",
          "description": "Heat source pattern name (e.g., uniform, dual_core, gpu_die)",
          "dataType": "sc:Text",
          "source": {
            "fileObject": {
              "@id": "metadata.parquet"
            },
            "extract": {
              "column": "heat_source_type"
            }
          }
        },
        {
          "@type": "cr:Field",
          "@id": "samples/feature_size",
          "name": "feature_size",
          "description": "Geometric feature size parameter (lattice units)",
          "dataType": "sc:Float",
          "source": {
            "fileObject": {
              "@id": "metadata.parquet"
            },
            "extract": {
              "column": "feature_size"
            }
          }
        },
        {
          "@type": "cr:Field",
          "@id": "samples/spacing",
          "name": "spacing",
          "description": "Geometric spacing parameter (lattice units)",
          "dataType": "sc:Float",
          "source": {
            "fileObject": {
              "@id": "metadata.parquet"
            },
            "extract": {
              "column": "spacing"
            }
          }
        },
        {
          "@type": "cr:Field",
          "@id": "samples/tau_fluid",
          "name": "tau_fluid",
