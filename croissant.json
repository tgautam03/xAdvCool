            "fileObject": {
              "@id": "metadata.parquet"
            },
            "extract": {
              "column": "Nu"
            }
          }
        },
        {
          "@type": "cr:Field",
          "@id": "samples/R_th",
          "name": "R_th",
          "description": "Thermal resistance (lattice units)",
          "dataType": "sc:Float",
          "source": {
            "fileObject": {
